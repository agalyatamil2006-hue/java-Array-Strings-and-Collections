import java.io.*;
import java.util.*;

public class Solution {


    public static int gcd(int a, int b) {
        while (b != 0) {
            int temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int a = sc.nextInt();
        int b = sc.nextInt();
        int c = sc.nextInt();

        // Find the second largest number
        int secondLargest;
        if ((a >= b && a <= c) || (a >= c && a <= b))
            secondLargest = a;
        else if ((b >= a && b <= c) || (b >= c && b <= a))
            secondLargest = b;
        else
            secondLargest = c;

        // Find GCD of all three numbers
        int code = gcd(gcd(a, b), c);

        System.out.println("The treasure is in the box which has number " + secondLargest + ".");
        System.out.println("The code to open the box is " + code + ".");
        
        sc.close();
    }
}
    
