import java.util.Scanner;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        n = Math.abs(n); // Ignore the sign if present

        int lastDigit = n % 10;

        int firstDigit = n;
        while (firstDigit >= 10) {
            firstDigit /= 10;
        }

        System.out.println(firstDigit + lastDigit);
    }
}
