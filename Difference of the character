import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Solution. */
        
        Scanner sc = new Scanner(System.in);

        String s = sc.nextLine();

        int star = 0, hash = 0;

        for (int i = 0; i < s.length(); i++) {
            if (s.charAt(i) == '*')
                star++;
            else if (s.charAt(i) == '#')
                hash++;
        }

        int diff = Math.abs(star - hash);

        System.out.print("The Difference of the character in the given string: ");

        if (diff % 2 == 0)
            System.out.printf("%02d", diff);
        else
            System.out.printf("%03d", diff);

        sc.close();
    }
}
    
